# pmetal-midi environment configuration

# Alma server connection
ALMA_HOST=alma
ALMA_USER=mgrigorov

# Data directory on alma (mounted as /data in container)
DATA_DIR=/home/mgrigorov/pmetal-data

# Container settings
CONTAINER_NAME=pmetal-midi
IMAGE_NAME=localhost/pmetal-midi
IMAGE_TAG=latest
STATUS_PORT=8100

# LiteLLM (runs on Mac localhost, NOT on alma)
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-master-change-me
LITELLM_MODEL=qwen3-coder-30b-q8
